# Production PostgreSQL is provided through Supabase. Keep these values only
# in the deployment environment; never expose the service-role key to clients.
APP_ENVIRONMENT=production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used only by migration scripts/CI to apply SQL. Prefer Supabase's pooled
# connection string and never expose it to browser code.
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?sslmode=require

# One-time bootstrap protection for creating the first platform administrator.
ADMIN_SETUP_SECRET=replace-with-a-long-random-secret

# Required for signing and hashing application sessions.
SESSION_SECRET=replace-with-at-least-32-random-characters

# Optional public origin used for absolute links.
APP_ORIGIN=https://your-deployed-domain.example
