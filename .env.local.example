# Generated automatically by `pnpm db:local:setup` after the local Supabase
# stack starts. This example contains no usable service-role secret.
APP_ENVIRONMENT=local
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=copy-from-pnpm-supabase-status
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
ADMIN_SETUP_SECRET=replace-with-a-long-random-local-secret
SESSION_SECRET=replace-with-at-least-32-random-local-characters
APP_ORIGIN=http://127.0.0.1:5000
